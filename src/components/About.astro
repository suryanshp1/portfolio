---
// About.astro — Bento Grid redesign
---

<section id="about" class="section-padding about-section" aria-labelledby="about-heading">
  <div class="container-max">

    <!-- Section Label -->
    <div class="about-eyebrow">
      <span class="section-label" aria-hidden="true">01 — About</span>
    </div>

    <!-- Bento Grid -->
    <div class="bento-grid">

      <!-- ── CARD 1: Profile (tall left card) ──────────────────── -->
      <div class="bento-card profile-card" aria-label="Profile information">
        <div class="profile-mesh" aria-hidden="true"></div>
        <div class="profile-inner">
          <!-- Top: Monogram + Status -->
          <div class="profile-top">
            <div class="profile-avatar" aria-hidden="true">
              <span class="profile-initials">SP</span>
              <div class="profile-avatar-ring" aria-hidden="true"></div>
            </div>
            <span class="profile-status" aria-label="Currently available for opportunities">
              <span class="status-pulse" aria-hidden="true"></span>
              Available
            </span>
          </div>

          <!-- Name + Role -->
          <div class="profile-identity">
            <h2 id="about-heading" class="profile-name">
              Suryansh<br/>Pandey
            </h2>
            <p class="profile-role">Senior Backend & AI Engineer</p>
          </div>

          <!-- Meta row -->
          <div class="profile-meta">
            <span class="meta-chip">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              India
            </span>
            <span class="meta-chip">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
              4+ years
            </span>
          </div>

          <!-- Divider -->
          <hr class="profile-divider" aria-hidden="true" />

          <!-- Social links -->
          <div class="profile-socials" role="list" aria-label="Social profiles">
            <a href="https://github.com/suryanshp1" target="_blank" rel="noopener noreferrer" class="social-icon-btn" aria-label="GitHub (opens in new tab)" role="listitem">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
              <span class="social-label">GitHub</span>
            </a>
            <a href="https://linkedin.com/in/suryanshp1" target="_blank" rel="noopener noreferrer" class="social-icon-btn" aria-label="LinkedIn (opens in new tab)" role="listitem">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              <span class="social-label">LinkedIn</span>
            </a>
            <a href="mailto:suryanshp1@gmail.com" class="social-icon-btn" aria-label="Send email" role="listitem">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              <span class="social-label">Email</span>
            </a>
            <a href="https://twitter.com/suryanshp1" target="_blank" rel="noopener noreferrer" class="social-icon-btn" aria-label="Twitter (opens in new tab)" role="listitem">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
              </svg>
              <span class="social-label">Twitter</span>
            </a>
          </div>

          <!-- Spacer -->
          <div style="flex: 1" aria-hidden="true"></div>

          <!-- Company badge at bottom -->
          <div class="profile-company" aria-label="Current employer">
            <div class="company-dot" aria-hidden="true"></div>
            <div>
              <p class="company-name">Strobes Security, Inc.</p>
              <p class="company-role">Since 2022</p>
            </div>
          </div>
        </div>
      </div>

      <!-- ── CARD 2: Code / Profile DNA (top center, spans 2) ──── -->
      <div class="bento-card code-card" aria-label="Developer profile as code">
        <div class="code-card-header" aria-hidden="true">
          <span class="code-dot" style="background:#ff5f57"></span>
          <span class="code-dot" style="background:#febc2e"></span>
          <span class="code-dot" style="background:#28c840"></span>
          <span class="code-filename">profile.py</span>
        </div>
        <pre class="code-block-inner" aria-label="Python profile class" role="img"><code><span class="t-keyword">@dataclass</span>
<span class="t-keyword">class</span> <span class="t-type">Engineer</span><span class="t-var">:</span>
  <span class="t-var">name</span>     <span class="t-keyword">=</span> <span class="t-str">"Suryansh Pandey"</span>
  <span class="t-var">role</span>     <span class="t-keyword">=</span> <span class="t-str">"Senior Backend & AI"</span>
  <span class="t-var">company</span>  <span class="t-keyword">=</span> <span class="t-str">"Strobes Security"</span>
  <span class="t-var">stack</span>    <span class="t-keyword">=</span> <span class="t-var">[</span>
    <span class="t-str">"Python"</span><span class="t-var">,</span> <span class="t-str">"FastAPI"</span><span class="t-var">,</span>
    <span class="t-str">"LangChain"</span><span class="t-var">,</span> <span class="t-str">"LangGraph"</span><span class="t-var">,</span>
    <span class="t-str">"AWS"</span><span class="t-var">,</span> <span class="t-str">"Terraform"</span><span class="t-var">,</span>
  <span class="t-var">]</span>
  <span class="t-var">experience</span> <span class="t-keyword">=</span> <span class="t-num">4</span>  <span class="t-comment"># years</span>
  <span class="t-var">open_to</span>    <span class="t-keyword">=</span> <span class="t-var">[</span><span class="t-str">"senior roles"</span><span class="t-var">,</span> <span class="t-str">"consulting"</span><span class="t-var">]</span>

  <span class="t-keyword">def</span> <span class="t-fn">mission</span><span class="t-var">(</span><span class="t-keyword">self</span><span class="t-var">):</span>
    <span class="t-keyword">return</span> <span class="t-str">"Build systems that think."</span></code></pre>
        <!-- Subtle blue glow -->
        <div class="code-glow" aria-hidden="true"></div>
      </div>

      <!-- ── CARD 3: Stats strip ───────────────────────────────── -->
      <div class="bento-card stats-card" aria-label="Career statistics">
        <div class="stats-row">
          <div class="stat-block">
            <span class="stat-num">4+</span>
            <span class="stat-desc">Years building<br/>production systems</span>
          </div>
          <div class="stat-sep" aria-hidden="true"></div>
          <div class="stat-block">
            <span class="stat-num">10M+</span>
            <span class="stat-desc">Events processed<br/>per day at Strobes</span>
          </div>
          <div class="stat-sep" aria-hidden="true"></div>
          <div class="stat-block">
            <span class="stat-num">60%</span>
            <span class="stat-desc">Analyst time saved<br/>via AI triage</span>
          </div>
        </div>
      </div>

      <!-- ── CARD 4: What I build (specialty chips) ────────────── -->
      <div class="bento-card specialty-card" aria-label="Areas of specialization">
        <p class="specialty-eyebrow">What I build</p>
        <div class="specialty-chips">
          {[
            { icon: '⚡', label: 'Distributed Backends' },
            { icon: '🤖', label: 'Agentic AI Systems' },
            { icon: '🔍', label: 'RAG Pipelines' },
            { icon: '☁️', label: 'Cloud Infrastructure' },
            { icon: '🔒', label: 'DevSecOps' },
            { icon: '📡', label: 'Event-Driven Arch' },
            { icon: '🧠', label: 'LLM Workflows' },
            { icon: '🐘', label: 'Data Engineering' },
          ].map(c => (
            <span class="specialty-chip">
              <span aria-hidden="true">{c.icon}</span>
              {c.label}
            </span>
          ))}
        </div>
      </div>

      <!-- ── CARD 5: Mission statement (large pull-quote) ─────── -->
      <div class="bento-card mission-card" aria-label="Personal mission statement">
        <div class="mission-quote-mark" aria-hidden="true">"</div>
        <blockquote class="mission-text">
          I turn hard distributed systems problems into clean,
          observable, production-grade solutions — then make them
          <em>think</em> with AI.
        </blockquote>
        <p class="mission-author">— Suryansh Pandey</p>
      </div>

    </div>
  </div>
</section>

<style>
  .about-section {
    border-top: 1px solid var(--color-hairline-soft);
  }

  .about-eyebrow {
    margin-bottom: 40px;
  }

  /* ── Bento Grid ──────────────────────────────────────────────── */
  .bento-grid {
    display: grid;
    grid-template-columns: 280px 1fr 1fr;
    grid-template-rows: auto auto auto;
    gap: 12px;
  }

  /* Card base */
  .bento-card {
    background: var(--color-surface-card);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-xl);
    overflow: hidden;
    position: relative;
    transition: border-color 0.2s ease;
  }
  .bento-card:hover {
    border-color: var(--color-hairline-strong);
  }

  /* Grid placement */
  .profile-card  { grid-column: 1; grid-row: 1 / span 3; }
  .code-card     { grid-column: 2 / span 2; grid-row: 1; }
  .stats-card    { grid-column: 2 / span 2; grid-row: 2; }
  .specialty-card { grid-column: 2; grid-row: 3; }
  .mission-card  { grid-column: 3; grid-row: 3; }

  /* ── Profile Card ────────────────────────────────────────────── */
  .profile-card {
    padding: 0;
  }

  .profile-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 120% 50% at 50% -20%, rgba(26, 38, 255, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 80% 40% at 100% 100%, rgba(0, 212, 255, 0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .profile-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 24px;
    min-height: 480px;
  }

  .profile-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 28px;
    gap: 16px;
  }

  .profile-avatar {
    position: relative;
    width: 64px;
    height: 64px;
  }

  .profile-initials {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-lg);
    font-size: 20px;
    font-weight: 600;
    letter-spacing: 1px;
    font-family: var(--font-sans);
  }

  .profile-avatar-ring {
    position: absolute;
    inset: -3px;
    border-radius: calc(var(--radius-lg) + 3px);
    border: 1px solid rgba(26, 38, 255, 0.3);
    pointer-events: none;
  }

  .profile-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    background: rgba(51, 209, 122, 0.1);
    border: 1px solid rgba(51, 209, 122, 0.25);
    border-radius: var(--radius-pill);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-success);
    letter-spacing: 0.3px;
  }

  .status-pulse {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-success);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(51,209,122,0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 4px rgba(51,209,122,0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .status-pulse { animation: none; }
  }

  .profile-identity {
    margin-bottom: 20px;
  }

  .profile-name {
    font-size: clamp(32px, 3vw, 40px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -1.5px;
    color: var(--color-ink);
    margin: 0 0 10px;
    text-wrap: balance;
  }

  .profile-role {
    font-size: 13px;
    color: var(--color-muted);
    margin: 0;
    line-height: 1.4;
  }

  .profile-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .meta-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    background: var(--color-surface-card-elevated);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-pill);
    font-size: 11px;
    color: var(--color-muted);
  }

  .profile-divider {
    border: none;
    border-top: 1px solid var(--color-hairline);
    margin: 0 0 20px;
  }

  /* Social links */
  .profile-socials {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .social-icon-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    color: var(--color-muted);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .social-icon-btn:hover {
    background: var(--color-surface-card-elevated);
    border-color: var(--color-hairline);
    color: var(--color-ink);
  }

  .social-icon-btn:focus-visible {
    outline: 2px solid rgba(26, 38, 255, 0.6);
    outline-offset: 2px;
  }

  .social-label {
    font-size: 13px;
  }

  /* Company badge */
  .profile-company {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 12px;
    background: var(--color-surface-card-elevated);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    margin-top: 20px;
  }

  .company-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
    flex-shrink: 0;
    box-shadow: 0 0 8px rgba(26, 38, 255, 0.5);
  }

  .company-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-body-strong);
    margin: 0 0 2px;
  }

  .company-role {
    font-size: 11px;
    color: var(--color-muted);
    margin: 0;
  }

  /* ── Code Card ───────────────────────────────────────────────── */
  .code-card {
    padding: 0;
    background: var(--color-canvas-deep);
    border-color: var(--color-hairline-soft);
  }

  .code-card-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-hairline-soft);
  }

  .code-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .code-filename {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
    margin-left: 4px;
  }

  .code-block-inner {
    margin: 0;
    padding: 20px 20px 24px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.7;
    overflow: auto;
  }

  .code-glow {
    position: absolute;
    bottom: -20px;
    right: 60px;
    width: 200px;
    height: 100px;
    background: radial-gradient(ellipse, rgba(26,38,255,0.15) 0%, transparent 70%);
    pointer-events: none;
    filter: blur(16px);
  }

  /* Code syntax */
  .t-keyword  { color: #7b8fff; }
  .t-type     { color: var(--color-accent-cyan); }
  .t-str      { color: #a8d4a8; }
  .t-fn       { color: #e2a97e; }
  .t-var      { color: var(--color-body); }
  .t-comment  { color: var(--color-muted-soft); font-style: italic; }
  .t-num      { color: #e2a97e; }
  .t-decorator { color: #c792ea; }

  /* ── Stats Card ──────────────────────────────────────────────── */
  .stats-card {
    padding: 28px 32px;
    background: var(--color-surface-card);
  }

  .stats-row {
    display: flex;
    align-items: center;
    gap: 0;
    height: 100%;
  }

  .stat-block {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 0 24px;
  }

  .stat-block:first-child {
    padding-left: 0;
  }

  .stat-block:last-child {
    padding-right: 0;
  }

  .stat-num {
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: -1.5px;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .stat-desc {
    font-size: 12px;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .stat-sep {
    width: 1px;
    height: 48px;
    background: var(--color-hairline);
    flex-shrink: 0;
  }

  /* ── Specialty Card ──────────────────────────────────────────── */
  .specialty-card {
    padding: 24px;
  }

  .specialty-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.88px;
    text-transform: uppercase;
    color: var(--color-muted-soft);
    margin: 0 0 16px;
  }

  .specialty-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .specialty-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: var(--color-surface-card-elevated);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-body);
    cursor: default;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
  }

  .specialty-chip:hover {
    border-color: rgba(26, 38, 255, 0.4);
    color: var(--color-ink);
    background: rgba(26, 38, 255, 0.06);
  }

  /* ── Mission Card ────────────────────────────────────────────── */
  .mission-card {
    padding: 32px 28px;
    background: var(--color-surface-card);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }

  .mission-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(26,38,255,0.5), transparent);
  }

  .mission-quote-mark {
    font-size: 80px;
    line-height: 0.6;
    color: rgba(26, 38, 255, 0.2);
    font-family: Georgia, serif;
    font-weight: 700;
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .mission-text {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.65;
    color: var(--color-body);
    margin: 0 0 16px;
    font-style: normal;
    flex: 1;
  }

  .mission-text em {
    color: var(--color-ink);
    font-style: normal;
    font-weight: 500;
  }

  .mission-author {
    font-size: 12px;
    color: var(--color-muted-soft);
    margin: 0;
    font-family: var(--font-mono);
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .bento-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
    }
    .profile-card  { grid-column: 1 / span 2; grid-row: 1; }
    .code-card     { grid-column: 1 / span 2; grid-row: 2; }
    .stats-card    { grid-column: 1 / span 2; grid-row: 3; }
    .specialty-card { grid-column: 1; grid-row: 4; }
    .mission-card  { grid-column: 2; grid-row: 4; }

    .profile-inner {
      min-height: auto;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 20px;
      align-items: flex-start;
    }

    .profile-top { margin-bottom: 0; flex: 0 0 auto; }
    .profile-identity { flex: 1; min-width: 200px; }
    .profile-meta { flex-basis: 100%; }
    .profile-divider { flex-basis: 100%; margin-bottom: 0; }
    .profile-socials {
      flex-direction: row;

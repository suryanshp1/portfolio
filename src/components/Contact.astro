---
// Contact.astro — CTA band with spotlight glow + contact links
---

<section id="contact" class="section-padding contact-section" aria-labelledby="contact-heading">
  <!-- Spotlight glow backdrop -->
  <div class="contact-glow" aria-hidden="true"></div>

  <div class="container-max contact-inner">
    <!-- Header -->
    <div class="contact-header">
      <span class="section-label" aria-hidden="true">Contact</span>
      <h2 id="contact-heading" class="display-lg">
        Let's build something<br />
        <span class="gradient-text">remarkable.</span>
      </h2>
      <p class="body-md contact-sub">
        Open to senior backend/AI engineering roles, technical consulting, 
        and interesting open-source collaborations. 
        I respond to all messages within 24 hours.
      </p>
    </div>

    <!-- Contact cards -->
    <div class="contact-cards" role="list">
      <a
        href="mailto:suryanshp1@gmail.com"
        class="contact-card feature-card"
        role="listitem"
        aria-label="Send email to suryanshp1@gmail.com"
      >
        <div class="contact-card-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </div>
        <div>
          <p class="title-sm contact-card-title">Email</p>
          <p class="body-sm contact-card-value">suryanshp1@gmail.com</p>
        </div>
        <div class="contact-arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </div>
      </a>

      <a
        href="https://linkedin.com/in/suryanshp1"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card feature-card"
        role="listitem"
        aria-label="LinkedIn profile (opens in new tab)"
      >
        <div class="contact-card-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <div>
          <p class="title-sm contact-card-title">LinkedIn</p>
          <p class="body-sm contact-card-value">linkedin.com/in/suryanshp1</p>
        </div>
        <div class="contact-arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </div>
      </a>

      <a
        href="https://github.com/suryanshp1"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card feature-card"
        role="listitem"
        aria-label="GitHub profile (opens in new tab)"
      >
        <div class="contact-card-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </div>
        <div>
          <p class="title-sm contact-card-title">GitHub</p>
          <p class="body-sm contact-card-value">github.com/suryanshp1</p>
        </div>
        <div class="contact-arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </div>
      </a>

      <a
        href="https://twitter.com/suryanshp1"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card feature-card"
        role="listitem"
        aria-label="Twitter/X profile (opens in new tab)"
      >
        <div class="contact-card-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
          </svg>
        </div>
        <div>
          <p class="title-sm contact-card-title">Twitter / X</p>
          <p class="body-sm contact-card-value">@suryanshp1</p>
        </div>
        <div class="contact-arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </div>
      </a>
    </div>

    <!-- Primary CTA -->
    <div class="contact-cta-row">
      <a
        href="mailto:suryanshp1@gmail.com"
        class="btn-primary contact-btn"
        aria-label="Send an email to Suryansh"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        Send me an email
      </a>
      <p class="body-sm contact-note">
        Typically respond within 24 hours &nbsp;·&nbsp; Based in India
      </p>
    </div>
  </div>
</section>

<style>
  .contact-section {
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--color-hairline-soft);
    text-align: center;
  }

  .contact-glow {
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(26, 38, 255, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .contact-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .contact-header {
    max-width: 600px;
  }

  .section-label {
    display: block;
    margin-bottom: 16px;
  }

  .contact-sub {
    margin-top: 16px;
    max-width: 480px;
    margin-inline: auto;
  }

  /* Contact cards */
  .contact-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    width: 100%;
    max-width: 640px;
    text-align: left;
  }

  @media (max-width: 480px) {
    .contact-cards {
      grid-template-columns: 1fr;
    }
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    padding: 20px;
    border-radius: var(--radius-lg);
    transition: border-color 0.15s ease, transform 0.2s ease;
  }

  .contact-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-hairline-strong);
  }

  .contact-card:hover .contact-arrow {
    color: var(--color-ink);
  }

  .contact-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--color-surface-card-elevated);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    color: var(--color-body);
    flex-shrink: 0;
  }

  .contact-card-title {
    margin: 0 0 2px;
  }

  .contact-card-value {
    margin: 0;
    color: var(--color-muted);
    font-size: 12px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .contact-arrow {
    margin-left: auto;
    color: var(--color-muted-soft);
    transition: color 0.15s ease;
    flex-shrink: 0;
  }

  /* CTA */
  .contact-cta-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .contact-btn {
    height: 44px;
    padding: 12px 24px;
    font-size: 15px;
  }

  .contact-note {
    color: var(--color-muted-soft);
    font-size: 13px;
    margin: 0;
  }
</style>

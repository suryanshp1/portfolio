---
// Experience.astro
const experiences = [
  {
    company: 'Strobes Security, Inc.',
    companyUrl: 'https://strobes.co',
    role: 'Senior Backend Engineer & AI Lead',
    period: '2022 — Present',
    duration: '3+ years',
    location: 'Remote',
    type: 'Full-time',
    description: 'Leading backend architecture and AI integration for an enterprise security platform used by global organizations to manage vulnerabilities, penetration testing, and compliance.',
    highlights: [
      'Architected a distributed microservices platform handling 10M+ security events per day using FastAPI, Celery, RabbitMQ, and Redis.',
      'Built LLM-powered agentic workflows using LangChain and LangGraph for automated vulnerability triage and report generation, reducing analyst time by 60%.',
      'Designed and deployed RAG pipelines with Elasticsearch and vector databases for intelligent security knowledge retrieval.',
      'Implemented cloud-native infrastructure on AWS using Terraform, ECS, and GitHub Actions CI/CD pipelines.',
      'Led migration from monolith to event-driven microservices architecture, improving system resilience and deployment velocity.',
      'Integrated Elasticsearch for advanced threat search with sub-100ms query response across terabytes of security data.',
    ],
    tech: ['Python', 'FastAPI', 'Django', 'LangChain', 'LangGraph', 'Celery', 'RabbitMQ', 'Redis', 'PostgreSQL', 'Elasticsearch', 'Docker', 'AWS', 'Terraform'],
  },
  {
    company: 'Freelance / Open Source',
    companyUrl: 'https://github.com/suryanshp1',
    role: 'AI Engineer & Backend Consultant',
    period: '2021 — 2022',
    duration: '1 year',
    location: 'Remote',
    type: 'Contract',
    description: 'Delivered agentic AI solutions and scalable backend APIs for clients across fintech, healthcare, and SaaS domains.',
    highlights: [
      'Built production CrewAI multi-agent systems for document analysis and automated reporting workflows.',
      'Developed GraphQL APIs with Django and Strawberry for real-time data platforms.',
      'Created FastAPI microservices with async PostgreSQL, achieving 3x throughput improvement.',
      'Contributed to open-source AI tooling including LangChain integrations and Python utility libraries.',
    ],
    tech: ['Python', 'FastAPI', 'Django', 'GraphQL', 'CrewAI', 'LangChain', 'PostgreSQL', 'MongoDB', 'Docker'],
  },
];
---

<section id="experience" class="section-padding experience-section" aria-labelledby="experience-heading">
  <div class="container-max">
    <div class="section-header">
      <span class="section-label" aria-hidden="true">02 — Experience</span>
      <h2 id="experience-heading" class="display-lg">
        Where I've worked
      </h2>
    </div>

    <!-- Timeline -->
    <div class="timeline" role="list">
      {experiences.map((exp, i) => (
        <article class="timeline-entry" role="listitem" aria-label={`${exp.role} at ${exp.company}`}>
          <!-- Timeline indicator -->
          <div class="timeline-indicator" aria-hidden="true">
            <div class="timeline-dot">
              <div class="timeline-dot-inner"></div>
            </div>
            {i < experiences.length - 1 && <div class="timeline-line"></div>}
          </div>

          <!-- Content -->
          <div class="timeline-content feature-card">
            <!-- Header -->
            <div class="exp-header">
              <div class="exp-header-left">
                <div class="exp-company-row">
                  <a
                    href={exp.companyUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="exp-company-link"
                    aria-label={`${exp.company} website (opens in new tab)`}
                  >
                    {exp.company}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M7 7h10v10M7 17 17 7"/>
                    </svg>
                  </a>
                  <span class="badge-pill">{exp.type}</span>
                </div>
                <h3 class="exp-role display-sm">{exp.role}</h3>
              </div>
              <div class="exp-meta">
                <span class="exp-period">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                  </svg>
                  {exp.period}
                </span>
                <span class="exp-location">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                  {exp.location}
                </span>
              </div>
            </div>

            <!-- Description -->
            <p class="body-md exp-desc">{exp.description}</p>

            <!-- Highlights -->
            <ul class="exp-highlights" aria-label="Key achievements">
              {exp.highlights.map(h => (
                <li class="exp-highlight-item">
                  <span class="highlight-bullet" aria-hidden="true">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <path d="m9 18 6-6-6-6"/>
                    </svg>
                  </span>
                  <span class="body-sm exp-highlight-text">{h}</span>
                </li>
              ))}
            </ul>

            <!-- Tech Stack -->
            <div class="exp-tech" aria-label="Technologies used">
              {exp.tech.map(t => (
                <span class="tech-tag">{t}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Education footnote -->
    <div class="education-card feature-card" style="margin-top:32px;">
      <div class="edu-inner">
        <span class="edu-icon" aria-hidden="true">🎓</span>
        <div>
          <p class="title-sm" style="margin:0 0 4px;">B.Tech — Computer Science & Engineering</p>
          <p class="body-sm" style="color:var(--color-muted); margin:0;">
            Babu Banarasi Das National Institute of Technology & Management, Lucknow &nbsp;·&nbsp; 2017–2021
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .experience-section {
    border-top: 1px solid var(--color-hairline-soft);
  }

  .section-header {
    margin-bottom: 64px;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-entry {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 20px;
    position: relative;
  }

  /* Indicator */
  .timeline-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 6px;
  }

  .timeline-line {
    flex: 1;
    width: 1px;
    background: var(--color-hairline);
    margin-top: 8px;
    min-height: 32px;
  }

  /* Content */
  .timeline-content {
    margin-bottom: 24px;
  }

  /* Header */
  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .exp-company-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }

  .exp-company-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .exp-company-link:hover {
    color: var(--color-body-strong);
  }

  .exp-role {
    margin: 0;
    font-size: clamp(18px, 2vw, 24px);
  }

  .exp-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: flex-end;
    flex-shrink: 0;
  }

  .exp-period,
  .exp-location {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: var(--color-muted);
    white-space: nowrap;
  }

  /* Description */
  .exp-desc {
    color: var(--color-body);
    margin: 0 0 20px;
  }

  /* Highlights */
  .exp-highlights {
    list-style: none;
    margin: 0 0 20px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .exp-highlight-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .highlight-bullet {
    color: var(--color-primary-glow);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .exp-highlight-text {
    color: var(--color-body);
  }

  /* Tech */
  .exp-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding-top: 16px;
    border-top: 1px solid var(--color-hairline-soft);
  }

  .tech-tag {
    padding: 3px 8px;
    background: var(--color-surface-card-elevated);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-muted);
    font-family: var(--font-mono);
  }

  /* Education */
  .education-card {
    border-radius: var(--radius-lg);
  }

  .edu-inner {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .edu-icon {
    font-size: 24px;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .timeline-entry {
      grid-template-columns: 28px 1fr;
      gap: 12px;
    }
    .exp-meta {
      align-items: flex-start;
    }
    .exp-header {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>

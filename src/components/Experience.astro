---
// Experience.astro
const experiences = [
  {
    company: 'Strobes Security, Inc.',
    companyUrl: 'https://strobes.co',
    role: 'Senior Software Engineer',
    period: 'Aug 2025 — Jan 2026',
    duration: '',
    location: 'Remote',
    type: 'Senior Engineer',
    description: '',
    highlights: [
      'Architected and implemented a bi-directional GitHub Issues synchronization platform using GraphQL APIs, webhook-driven event orchestration, and idempotent reconciliation workflows, reliably processing 10k+ webhook events daily across 300+ enterprise tenants.',
      'Built a high-throughput enterprise export engine capable of processing 500k+ vulnerability and engagement records using optimized ORM execution plans, streaming batch pipelines, and concurrent background job execution.',
      'Developed a tenant-aware analytics framework supporting dynamic joins, aggregation pipelines, and self-serve dashboard generation across multi-table datasets serving 300+ concurrent enterprise tenants.',
      'Reduced priority score computation latency by 95%+ (2000s → 100s) through query-plan optimization, caching strategies, and elimination of redundant I/O operations.',
      'Improved release reliability and regression safety by expanding automated unit and integration test coverage across asynchronous processing services, distributed analytics pipelines, and concurrent background job workflows.',
    ],
    tech: ['Python', 'GraphQL', 'PostgreSQL', 'Webhooks', 'Batch Pipelines'],
  },
  {
    company: 'Strobes Security, Inc.',
    companyUrl: 'https://strobes.co',
    role: 'Software Engineer',
    period: 'Jan 2024 — Jul 2025',
    duration: '',
    location: 'Remote',
    type: 'AI Automation',
    description: '',
    highlights: [
      'Architected a customizable dashboard framework powering 7+ analytical widget types across vulnerability, asset, and engagement datasets supporting 300+ tenant-scoped enterprise environments.',
      'Designed and developed AI-driven security automation workflows for remediation orchestration, lifecycle management, and infrastructure operations supporting concurrent asynchronous task execution pipelines.',
      'Built an autonomous code remediation agent using AIDER and Claude Sonnet to generate contextual vulnerability fixes, perform diff-aware reasoning, and automate pull request generation across concurrent CI workflows.',
      'Engineered a rollback-safe cloud remediation platform using LangChain, Terraform, Celery, and RabbitMQ to detect infrastructure misconfigurations and execute concurrent remediation workflows with audit-safe rollback mechanisms.',
      'Integrated AWS Bedrock, OpenAI, LangChain, and FastAPI streaming pipelines to power a contextual AI security assistant supporting low-latency real-time response streaming and session-aware memory management.',
      'Developed an NLP-based vulnerability severity classification engine using TF-IDF vectorization and NLTK pipelines for automated risk categorization from unstructured findings.',
      'Generated synthetic vulnerability datasets using LLaMA 3.1 to support internal AI experimentation, model evaluation workflows, and structured security-data simulation.',
      'Unified multiple security-scanner microservices into a normalized ingestion architecture with structured parsing, automated deduplication, asynchronous processing, and scalable event-driven ingestion pipelines.',
      'Delivered Azure Boards bi-directional synchronization workflows using REST APIs and webhook orchestration, reliably handling 10k+ external lifecycle events daily with idempotent state reconciliation.',
      'Modernized CSV ingestion workflows processing 500k+ records through schema-aware validation layers, granular error reporting, and scalable batch-processing pipelines.',
      'Built scalable PDF reporting infrastructure generating 5k+ tenant-scoped reports monthly using headless rendering pipelines and AWS S3 artifact storage.',
      'Implemented OAuth-based credential management workflows for GitHub and Jira integrations with scoped permissions and secure token storage mechanisms.',
    ],
    tech: ['FastAPI', 'LangChain', 'Terraform', 'Celery', 'RabbitMQ', 'AWS Bedrock', 'Claude Sonnet', 'LLaMA', 'NLTK', 'OAuth'],
  },
  {
    company: 'Strobes Security, Inc.',
    companyUrl: 'https://strobes.co',
    role: 'Junior Software Engineer',
    period: 'Apr 2022 — Dec 2023',
    duration: '',
    location: 'Hyderabad',
    type: 'Full-time',
    description: '',
    highlights: [
      'Designed and implemented an Asset and Vulnerability Archival System managing 500k+ records with lifecycle-aware data segregation and on-demand restoration capabilities in a multi-tenant SaaS environment.',
      'Integrated Microsoft Teams webhook-based notifications for automated vulnerability updates, workflow alerts, and security event communication.',
      'Optimized high-volume bulk asset and vulnerability operations including bulk deletion of 500k+ records through query refactoring, batch execution optimization, and asynchronous processing improvements.',
      'Analyzed ORM execution patterns using Django Silk to identify N+1 queries, optimize database access strategies, and reduce production API latency by 70% under high-volume workloads.',
      'Designed and implemented an end-to-end History API enabling audit trails, version-level traceability, and lifecycle change tracking across assets and vulnerabilities.',
      'Configured SLA rule-processing logic and implemented an Engagement Credits API supporting automated PTaaS workflow execution and credit allocation mechanisms.',
      'Authored internal technical documentation for dashboard systems, widget architecture, and backend workflows to streamline onboarding and improve engineering clarity.',
    ],
    tech: ['Python', 'Django', 'Django REST Framework', 'PostgreSQL', 'Django Silk'],
  },
  {
    company: 'Strobes Security, Inc.',
    companyUrl: 'https://strobes.co',
    role: 'Software Engineering Intern',
    period: 'Nov 2021 — Mar 2022',
    duration: '',
    location: 'Hyderabad',
    type: 'Intern',
    description: '',
    highlights: [
      'Developed a full-stack blog platform using Django REST Framework, GraphQL, PostgreSQL, and JWT-based authentication with production-style API architecture.',
      'Diagnosed and resolved backend production issues within the Strobes API ecosystem, improving service reliability and deployment stability.',
      'Contributed to backend platform development using Python, Django, DRF, GraphQL, and Docker within a production cybersecurity SaaS environment.',
    ],
    tech: ['Python', 'Django', 'GraphQL', 'Docker', 'PostgreSQL', 'JWT'],
  },
];
---

<section id="experience" class="section-padding experience-section" aria-labelledby="experience-heading">
  <div class="container-max">
    <div class="section-header">
      <span class="section-label" aria-hidden="true">Experience</span>
      <h2 id="experience-heading" class="display-lg">
        Where I've worked
      </h2>
    </div>

    <!-- Timeline -->
    <div class="timeline" role="list">
      {experiences.map((exp, i) => (
        <article class="timeline-entry" role="listitem" aria-label={`${exp.role} at ${exp.company}`}>
          <!-- Timeline indicator -->
          <div class="timeline-indicator" aria-hidden="true">
            <div class="timeline-dot">
              <div class="timeline-dot-inner"></div>
            </div>
            {i < experiences.length - 1 && <div class="timeline-line"></div>}
          </div>

          <!-- Content -->
          <div class="timeline-content feature-card">
            <!-- Header -->
            <div class="exp-header">
              <div class="exp-header-left">
                <div class="exp-company-row">
                  <a
                    href={exp.companyUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="exp-company-link"
                    aria-label={`${exp.company} website (opens in new tab)`}
                  >
                    {exp.company}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M7 7h10v10M7 17 17 7"/>
                    </svg>
                  </a>
                  <span class="badge-pill">{exp.type}</span>
                </div>
                <h3 class="exp-role display-sm">{exp.role}</h3>
              </div>
              <div class="exp-meta">
                <span class="exp-period">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                  </svg>
                  {exp.period}
                </span>
                <span class="exp-location">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                  {exp.location}
                </span>
              </div>
            </div>

            <!-- Description -->
            {exp.description && <p class="body-md exp-desc">{exp.description}</p>}

            <!-- Highlights -->
            <ul class="exp-highlights" aria-label="Key achievements">
              {exp.highlights.map(h => (
                <li class="exp-highlight-item">
                  <span class="highlight-bullet" aria-hidden="true">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <path d="m9 18 6-6-6-6"/>
                    </svg>
                  </span>
                  <span class="body-sm exp-highlight-text">{h}</span>
                </li>
              ))}
            </ul>

            <!-- Tech Stack -->
            <div class="exp-tech" aria-label="Technologies used">
              {exp.tech.map(t => (
                <span class="tech-tag">{t}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Education footnote -->
    <div class="education-card feature-card" style="margin-top:32px;">
      <div class="edu-inner">
        <span class="edu-icon" aria-hidden="true">🎓</span>
        <div>
          <p class="title-sm" style="margin:0 0 4px;">B.Tech — Computer Science & Engineering</p>
          <p class="body-sm" style="color:var(--color-muted); margin:0;">
            Babu Banarasi Das National Institute of Technology & Management, Lucknow &nbsp;·&nbsp; 2017–2021
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .experience-section {
    border-top: 1px solid var(--color-hairline-soft);
  }

  .section-header {
    margin-bottom: 64px;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-entry {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 20px;
    position: relative;
  }

  /* Indicator */
  .timeline-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 6px;
  }

  .timeline-line {
    flex: 1;
    width: 1px;
    background: var(--color-hairline);
    margin-top: 8px;
    min-height: 32px;
  }

  /* Content */
  .timeline-content {
    margin-bottom: 24px;
  }

  /* Header */
  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .exp-company-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }

  .exp-company-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .exp-company-link:hover {
    color: var(--color-body-strong);
  }

  .exp-role {
    margin: 0;
    font-size: clamp(18px, 2vw, 24px);
  }

  .exp-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: flex-end;
    flex-shrink: 0;
  }

  .exp-period,
  .exp-location {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: var(--color-muted);
    white-space: nowrap;
  }

  /* Description */
  .exp-desc {
    color: var(--color-body);
    margin: 0 0 20px;
  }

  /* Highlights */
  .exp-highlights {
    list-style: none;
    margin: 0 0 20px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .exp-highlight-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .highlight-bullet {
    color: var(--color-primary-glow);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .exp-highlight-text {
    color: var(--color-body);
  }

  /* Tech */
  .exp-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding-top: 16px;
    border-top: 1px solid var(--color-hairline-soft);
  }

  .tech-tag {
    padding: 3px 8px;
    background: var(--color-surface-card-elevated);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-muted);
    font-family: var(--font-mono);
  }

  /* Education */
  .education-card {
    border-radius: var(--radius-lg);
  }

  .edu-inner {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .edu-icon {
    font-size: 24px;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .timeline-entry {
      grid-template-columns: 28px 1fr;
      gap: 12px;
    }
    .exp-meta {
      align-items: flex-start;
    }
    .exp-header {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>

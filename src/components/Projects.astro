---
// Projects.astro
const projects = [
  {
    id: 'automated-pr-reviewer',
    title: 'Automated PR Reviewer',
    subtitle: 'AI agent for automated code reviews',
    description:
      'AI agent for automated code reviews integrated into CI/CD pipelines. Detects issues and suggests improvements automatically.',
    highlights: [
      'Integrates seamlessly into CI/CD pipelines',
      'Detects code issues and anti-patterns',
      'Suggests automated improvements via CrewAI',
    ],
    tech: ['Python', 'CrewAI', 'GitHub Actions', 'FastAPI'],
    category: 'AI Tooling',
    categoryColor: '#33d17a',
    status: 'Open Source',
    links: {
      github: 'https://github.com/suryanshp1/automated-pr-reviewer-ci-agent',
    },
  },
  {
    id: 'play-store-trend-agent',
    title: 'Play Store Trend Agent',
    subtitle: 'Agentic analysis of Play Store reviews',
    description:
      'Agentic analysis of Play Store reviews with semantic deduplication, trend tracking, and interactive dashboard.',
    tech: ['Python', 'FastAPI', 'PostgreSQL', 'pgvector', 'Streamlit'],
    category: 'AI / Data',
    categoryColor: '#6b7fff',
    status: 'Open Source',
    links: {
      github: 'https://github.com/suryanshp1/play-store-review-trend-agent',
    },
  },
  {
    id: 'advanced-coding-cli',
    title: 'Advanced Coding CLI',
    subtitle: 'Terminal-based AI coding assistant',
    description:
      'Terminal-based AI coding assistant with Model Context Protocol (MCP) support and interactive TUI.',
    tech: ['Python', 'CLI', 'MCP', 'LLM'],
    category: 'Developer Tools',
    categoryColor: '#c792ea',
    status: 'Open Source',
    links: {
      github: 'https://github.com/suryanshp1/advance-coding-cli-agent',
    },
  },
  {
    id: 'simplecdc',
    title: 'SimpleCDC',
    subtitle: 'Real-time PostgreSQL changes',
    description:
      'Lightweight CDC platform that monitors PostgreSQL database changes in real time and streams them to a web dashboard.',
    tech: ['Python', 'PostgreSQL', 'FastAPI', 'React', 'Docker'],
    category: 'Backend / Infra',
    categoryColor: '#00d4ff',
    status: 'Open Source',
    links: {
      github: 'https://github.com/suryanshp1/simple-cdc',
    },
  },
  {
    id: 'bluesky-ai-agent',
    title: 'Bluesky AI Agent',
    subtitle: 'Agentic content automation platform',
    description:
      'Agentic content automation platform using multi-agent orchestration. Enabled real-time Bluesky integration for LLM-powered workflows.',
    tech: ['Python', 'LangChain', 'Groq', 'Atproto'],
    category: 'AI / Social',
    categoryColor: '#ffbc2e',
    status: 'Open Source',
    links: {
      github: 'https://github.com/suryanshp1/bluesky-ebook-generator-ai-agent',
    },
  },
  {
    id: 'nlp-bug-severity-predictor',
    title: 'NLP Bug Severity Predictor',
    subtitle: 'Predict vulnerability severity',
    description:
      'API to predict vulnerability severity based on description using NLP techniques. Dockerized for easy deployment.',
    tech: ['Python', 'Docker', 'FastAPI', 'NLP'],
    category: 'Machine Learning',
    categoryColor: '#ff5f57',
    status: 'Open Source',
    links: {
      github: 'https://github.com/suryanshp1/nlp-bug-severity-predictor',
    },
  },
  {
    id: 'gem-price-prediction',
    title: 'Gem Price Prediction Pipeline',
    subtitle: 'End-to-end MLOps pipeline',
    description:
      'End-to-end MLOps pipeline for gemstone price prediction. Features DVC for data versioning and Azure for cloud deployment.',
    tech: ['Python', 'MLOps', 'Docker', 'Azure', 'DVC'],
    category: 'MLOps',
    categoryColor: '#e2a97e',
    status: 'Open Source',
    links: {
      github: 'https://github.com/suryanshp1/Gem-Price-Prediction-end-to-end-pipeline',
    },
  },
  {
    id: 'medical-chatbot-rag',
    title: 'Medical Chatbot RAG',
    subtitle: 'RAG-based medical queries',
    description:
      'RAG-based medical chatbot utilizing Llama2 and Pinecone for semantic search and reliable medical query answering.',
    tech: ['Python', 'LangChain', 'Flask', 'Llama2', 'Pinecone'],
    category: 'AI / RAG',
    categoryColor: '#6b7fff',
    status: 'Open Source',
    links: {
      github: 'https://github.com/suryanshp1/End-to-end-medical-chatbot',
    },
  },
  {
    id: 'ai-trip-planner',
    title: 'AI Trip Planner',
    subtitle: 'Multi-agent travel planning system',
    description:
      'Multi-agent travel planning system with dynamic risk assessment, budget optimization, and crowd density prediction.',
    tech: ['Python', 'CrewAI', 'LangChain', 'Docker'],
    category: 'AI Tooling',
    categoryColor: '#33d17a',
    status: 'Open Source',
    links: {
      github: 'https://github.com/suryanshp1/trip-planner-crewai',
    },
  },
  {
    id: 'social-media-api',
    title: 'Social Media API',
    subtitle: 'Robust FastAPI backend',
    description:
      'A robust social media application backend built with FastAPI, demonstrating best practices in API development.',
    tech: ['Python', 'FastAPI'],
    category: 'Backend API',
    categoryColor: '#00d4ff',
    status: 'Open Source',
    links: {
      github: 'https://github.com/suryanshp1/social-media-app',
    },
  },
];
---

<section id="projects" class="section-padding projects-section" aria-labelledby="projects-heading">
  <div class="container-max">
    <div class="section-header">
      <span class="section-label" aria-hidden="true">Projects</span>
      <h2 id="projects-heading" class="display-lg">
        Things I've built
      </h2>
      <p class="body-md projects-lead">
        A selection of production systems and side projects spanning AI agents,
        distributed backends, and cloud infrastructure.
      </p>
    </div>

    <!-- Featured project (first one) -->
    <div class="featured-project feature-card" aria-label="Featured project">
      <div class="featured-glow" aria-hidden="true"></div>
      <div class="featured-inner">
        <div class="featured-content">
          <div class="featured-meta">
            <span class="badge-pill" style={`color:${projects[0].categoryColor}; border-color: ${projects[0].categoryColor}33; background: ${projects[0].categoryColor}15;`}>
              {projects[0].category}
            </span>
            <span class="badge-pill" style="color: var(--color-success);">
              ● {projects[0].status}
            </span>
          </div>
          <h3 class="display-md featured-title">{projects[0].title}</h3>
          <p class="body-md featured-subtitle" style="color:var(--color-muted); margin-bottom:16px;">{projects[0].subtitle}</p>
          <p class="body-md" style="color:var(--color-body);">{projects[0].description}</p>

          <ul class="featured-highlights" aria-label="Key highlights">
            {projects[0].highlights.map(h => (
              <li class="featured-highlight-item">
                <span class="highlight-bullet" aria-hidden="true">→</span>
                <span class="body-sm">{h}</span>
              </li>
            ))}
          </ul>

          <div class="featured-tech" aria-label="Technologies used">
            {projects[0].tech.map(t => <span class="tech-tag">{t}</span>)}
          </div>
        </div>

        <div class="featured-links">
          {projects[0].links.demo && (
            <a
              href={projects[0].links.demo}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary"
              aria-label={`Visit ${projects[0].title} (opens in new tab)`}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M7 7h10v10M7 17 17 7"/>
              </svg>
              Live Site
            </a>
          )}
          {projects[0].links.github && (
            <a
              href={projects[0].links.github}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-outline"
              aria-label={`View ${projects[0].title} on GitHub (opens in new tab)`}
            >
              GitHub
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Project grid (remaining) -->
    <div class="projects-grid">
      {projects.slice(1).map(project => (
        <article class="project-card feature-card" aria-label={project.title}>
          <div class="project-card-inner">
            <div class="project-meta">
              <span
                class="badge-pill project-category"
                style={`color:${project.categoryColor}; border-color:${project.categoryColor}33; background:${project.categoryColor}15;`}
              >
                {project.category}
              </span>
              <span class="project-status body-sm" style="color:var(--color-muted);">
                {project.status}
              </span>
            </div>

            <h3 class="title-md project-title">{project.title}</h3>
            <p class="body-sm project-subtitle" style="color:var(--color-muted);">{project.subtitle}</p>
            <p class="body-sm project-desc">{project.description}</p>

            <div class="project-tech" aria-label="Technologies used">
              {project.tech.slice(0, 4).map(t => <span class="tech-tag">{t}</span>)}
              {project.tech.length > 4 && (
                <span class="tech-tag tech-tag-more">+{project.tech.length - 4}</span>
              )}
            </div>

            <div class="project-links">
              {project.links.demo && (
                <a
                  href={project.links.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="project-link"
                  aria-label={`Visit ${project.title} (opens in new tab)`}
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M7 7h10v10M7 17 17 7"/>
                  </svg>
                  Demo
                </a>
              )}
              {project.links.github && (
                <a
                  href={project.links.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="project-link"
                  aria-label={`View ${project.title} on GitHub (opens in new tab)`}
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                  </svg>
                  GitHub
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- View more -->
    <div class="projects-cta">
      <a
        href="https://github.com/suryanshp1"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary"
        aria-label="View all projects on GitHub (opens in new tab)"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        View All on GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .projects-section {
    border-top: 1px solid var(--color-hairline-soft);
  }

  .section-header {
    margin-bottom: 64px;
  }

  .projects-lead {
    max-width: 520px;
    margin-top: 16px;
  }

  /* Featured project */
  .featured-project {
    position: relative;
    overflow: hidden;
    margin-bottom: 24px;
    border-radius: var(--radius-xl);
    padding: 36px;
  }

  .featured-glow {
    position: absolute;
    top: -80px;
    right: -80px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(26, 38, 255, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .featured-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .featured-inner {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
    }
  }

  .featured-content {
    flex: 1;
  }

  .featured-meta {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .featured-title {
    margin: 0 0 4px;
    font-size: clamp(22px, 2.5vw, 32px);
  }

  .featured-subtitle {
    font-size: 15px;
    margin-bottom: 16px;
  }

  .featured-highlights {
    list-style: none;
    margin: 16px 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .featured-highlight-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .highlight-bullet {
    color: var(--color-primary-glow);
    font-size: 13px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .featured-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 16px;
  }

  .featured-links {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
    flex-wrap: wrap;
    align-self: flex-end;
  }

  /* Project grid */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .projects-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .project-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .project-card-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 12px;
  }

  .project-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .project-title {
    margin: 0;
  }

  .project-subtitle {
    margin: 0;
    color: var(--color-muted);
  }

  .project-desc {
    color: var(--color-body);
    flex: 1;
    margin: 0;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .tech-tag {
    padding: 3px 8px;
    background: var(--color-surface-card-elevated);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-muted);
    font-family: var(--font-mono);
  }

  .tech-tag-more {
    color: var(--color-primary-glow);
    border-color: rgba(26, 38, 255, 0.3);
    background: rgba(26, 38, 255, 0.08);
  }

  .project-links {
    display: flex;
    gap: 10px;
    padding-top: 12px;
    border-top: 1px solid var(--color-hairline-soft);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .project-link:hover {
    color: var(--color-ink);
  }

  .project-link:focus-visible {
    outline: 2px solid rgba(26, 38, 255, 0.6);
    outline-offset: 3px;
    border-radius: var(--radius-xs);
  }

  /* CTA */
  .projects-cta {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }
</style>

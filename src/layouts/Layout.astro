---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Suryansh Pandey | Senior Backend & AI Engineer',
  description = 'Senior Backend & AI Engineer with 4+ years building scalable distributed systems, AI automation platforms, and enterprise-grade security products. Specialized in Python microservices, LLM-powered agents, and cloud-native platforms.',
  ogImage = 'https://suryanshp1.github.io/opengraph-image',
} = Astro.props;

const canonicalURL = 'https://suryanshp1.github.io';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Suryansh Pandey" />
    <meta name="keywords" content="Suryansh Pandey, Backend Engineer, AI Engineer, Python, Django, FastAPI, LangChain, LangGraph, Portfolio" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Suryansh Pandey Portfolio" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@curosepian" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts — preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebSite",
            "@id": "https://suryanshp1.github.io/#website",
            "name": "Suryansh Pandey Portfolio",
            "url": "https://suryanshp1.github.io",
            "description": "Senior Backend & AI Engineer with 4+ years of experience.",
            "inLanguage": "en-US"
          },
          {
            "@type": "Person",
            "@id": "https://suryanshp1.github.io/#person",
            "name": "Suryansh Pandey",
            "url": "https://suryanshp1.github.io",
            "jobTitle": "Senior Backend & AI Engineer",
            "worksFor": {
              "@type": "Organization",
              "name": "Strobes Security, Inc.",
              "url": "https://strobes.co"
            },
            "sameAs": [
              "https://github.com/suryanshp1",
              "https://linkedin.com/in/suryanshp1"
            ],
            "email": "suryanshp1@gmail.com"
          }
        ]
      }
    </script>
  </head>
  <body>
    <!-- Skip to main content for accessibility -->
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <slot />
  </body>
</html>
